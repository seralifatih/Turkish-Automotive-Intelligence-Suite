{
  "actorSpecification": 1,
  "name": "auto-price-tracker",
  "title": "Turkish Auto Price Tracker - Arabam and Sahibinden Valuation API",
  "description": "Search Arabam.com and Sahibinden.com for matching vehicles and return listing-level price records plus statistical valuation summaries, percentiles, mileage buckets, and seller-type breakdowns.",
  "version": "1.0.0",
  "buildTag": "latest",
  "dockerfile": "../Dockerfile",
  "dockerContextDir": "../../..",
  "readme": "./README.md",
  "input": "./input_schema.json",
  "output": "./output_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "summaries": {
          "title": "Price Summaries",
          "transformation": {
            "filter": "type == 'PRICE_SUMMARY'",
            "fields": [
              "vehicleSpec.make",
              "vehicleSpec.model",
              "vehicleSpec.yearRange",
              "totalListingsUsed",
              "overall.medianPrice",
              "overall.averagePrice",
              "overall.minPrice",
              "overall.maxPrice",
              "overall.stdDeviation",
              "generatedAt"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "vehicleSpec.make": { "label": "Make", "format": "text" },
              "vehicleSpec.model": { "label": "Model", "format": "text" },
              "vehicleSpec.yearRange": { "label": "Year Range", "format": "text" },
              "totalListingsUsed": { "label": "Listings Used", "format": "number" },
              "overall.medianPrice": { "label": "Median Price (TRY)", "format": "number" },
              "overall.averagePrice": { "label": "Avg Price (TRY)", "format": "number" },
              "overall.minPrice": { "label": "Min (TRY)", "format": "number" },
              "overall.maxPrice": { "label": "Max (TRY)", "format": "number" }
            }
          }
        },
        "priceRecords": {
          "title": "Individual Listings",
          "transformation": {
            "filter": "type == 'PRICE_RECORD'",
            "fields": [
              "platform",
              "make",
              "model",
              "year",
              "price",
              "mileage",
              "fuelType",
              "transmission",
              "sellerType",
              "city",
              "listingUrl"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "platform": { "label": "Platform", "format": "text" },
              "make": { "label": "Make", "format": "text" },
              "model": { "label": "Model", "format": "text" },
              "year": { "label": "Year", "format": "number" },
              "price": { "label": "Price (TRY)", "format": "number" },
              "mileage": { "label": "Mileage (km)", "format": "number" },
              "sellerType": { "label": "Seller", "format": "text" },
              "city": { "label": "City", "format": "text" }
            }
          }
        },
        "runSummary": {
          "title": "Run Summary",
          "transformation": {
            "filter": "type == 'RUN_SUMMARY'",
            "fields": [
              "totalVehicleSpecs",
              "totalPriceRecords",
              "platformResults.arabam",
              "platformResults.sahibinden",
              "platformResults.otomoto",
              "durationSeconds",
              "errors",
              "blockedPlatforms",
              "warnings"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "totalVehicleSpecs": { "label": "Vehicle Specs", "format": "number" },
              "totalPriceRecords": { "label": "Price Records", "format": "number" },
              "platformResults.arabam": { "label": "Arabam", "format": "number" },
              "platformResults.sahibinden": { "label": "Sahibinden", "format": "number" },
              "platformResults.otomoto": { "label": "OtoMoto", "format": "number" },
              "durationSeconds": { "label": "Duration (s)", "format": "number" },
              "errors": { "label": "Errors", "format": "number" },
              "blockedPlatforms": { "label": "Blocked Platforms", "format": "text" },
              "warnings": { "label": "Warnings", "format": "text" }
            }
          }
        }
      }
    }
  }
}
