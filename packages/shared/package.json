{
  "name": "@workspace/shared",
  "version": "1.0.0",
  "description": "Shared utilities for the Turkish Automotive Intelligence Suite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto-normalizer": {
      "types": "./dist/auto-normalizer.d.ts",
      "import": "./dist/auto-normalizer.js"
    },
    "./error-handler": {
      "types": "./dist/error-handler.d.ts",
      "import": "./dist/error-handler.js"
    },
    "./sahibinden-stealth": {
      "types": "./dist/sahibinden-stealth.d.ts",
      "import": "./dist/sahibinden-stealth.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "playwright": "^1.43.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "playwright": "^1.43.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}
