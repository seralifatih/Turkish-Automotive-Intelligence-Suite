{
  "actorSpecification": 1,
  "name": "arabam-vehicle-scraper",
  "title": "Arabam.com Vehicle Scraper - Turkish Auto Marketplace Data API",
  "description": "Extract structured used-car listings from Arabam.com, including price, mileage, specs, seller details, location, condition data, and optional detail-page enrichment.",
  "version": "1.0.0",
  "buildTag": "latest",
  "environmentVariables": {},
  "dockerfile": "../Dockerfile",
  "dockerContextDir": "../../..",
  "readme": "./README.md",
  "input": "./input_schema.json",
  "output": "./output_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Vehicle listings",
          "transformation": {
            "fields": [
              "listingId",
              "title",
              "make",
              "model",
              "year",
              "price",
              "mileage",
              "fuelType",
              "transmission",
              "city",
              "sellerType",
              "paintCondition",
              "url",
              "scrapedAt"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "listingId": { "label": "ID", "format": "text" },
              "title": { "label": "Title", "format": "text" },
              "make": { "label": "Make", "format": "text" },
              "model": { "label": "Model", "format": "text" },
              "year": { "label": "Year", "format": "number" },
              "price": { "label": "Price (TRY)", "format": "number" },
              "mileage": { "label": "Mileage (km)", "format": "number" },
              "fuelType": { "label": "Fuel", "format": "text" },
              "transmission": { "label": "Transmission", "format": "text" },
              "city": { "label": "City", "format": "text" },
              "sellerType": { "label": "Seller Type", "format": "text" },
              "url": { "label": "URL", "format": "link" }
            }
          }
        },
        "runSummary": {
          "title": "Run Summary",
          "transformation": {
            "filter": "type == 'RUN_SUMMARY'",
            "fields": [
              "totalRecords",
              "durationSeconds",
              "errors",
              "inputSummary.maxListings",
              "inputSummary.scrapeDetails",
              "inputSummary.initialRequests",
              "warnings"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "totalRecords": { "label": "Records", "format": "number" },
              "durationSeconds": { "label": "Duration (s)", "format": "number" },
              "errors": { "label": "Errors", "format": "number" },
              "inputSummary.maxListings": { "label": "Max Listings", "format": "number" },
              "inputSummary.scrapeDetails": { "label": "Scrape Details", "format": "boolean" },
              "inputSummary.initialRequests": { "label": "Initial Requests", "format": "number" },
              "warnings": { "label": "Warnings", "format": "text" }
            }
          }
        }
      }
    }
  }
}
