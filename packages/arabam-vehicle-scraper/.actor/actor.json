{
  "actorSpecification": 1,
  "name": "arabam-vehicle-scraper",
  "title": "Arabam.com Vehicle Scraper — Turkish Auto Marketplace Data API",
  "description": "Comprehensive vehicle listing extractor for arabam.com — Turkey's largest dedicated automotive marketplace. Scrapes full vehicle specs, paint condition, accident history, seller info, and pricing. Supports filter-based search and direct URL modes.",
  "version": "1.0.0",
  "buildTag": "latest",
  "environmentVariables": [],
  "dockerfile": "../Dockerfile",
  "dockerContextDir": "../..",
  "readme": "./README.md",
  "input": "./input_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Vehicle listings",
          "transformation": {
            "fields": [
              "listingId", "title", "make", "model", "year", "price",
              "mileage", "fuelType", "transmission", "city", "sellerType",
              "paintCondition", "url", "scrapedAt"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "listingId": { "label": "ID", "format": "text" },
              "title": { "label": "Title", "format": "text" },
              "make": { "label": "Make", "format": "text" },
              "model": { "label": "Model", "format": "text" },
              "year": { "label": "Year", "format": "number" },
              "price": { "label": "Price (TRY)", "format": "number" },
              "mileage": { "label": "Mileage (km)", "format": "number" },
              "fuelType": { "label": "Fuel", "format": "text" },
              "transmission": { "label": "Transmission", "format": "text" },
              "city": { "label": "City", "format": "text" },
              "sellerType": { "label": "Seller Type", "format": "text" },
              "url": { "label": "URL", "format": "link" }
            }
          }
        }
      }
    }
  }
}
